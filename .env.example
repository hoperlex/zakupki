# --- Database ---
DATABASE_URL=postgres://zakupki:zakupki@localhost:5432/zakupki

# --- API server ---
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development
# Comma-separated allowed web origins (CORS). Dev web runs on :5173.
WEB_ORIGIN=http://localhost:5173

# --- Auth secrets (CHANGE IN PROD) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-0123456789
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-0123456789
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# --- File storage ---
STORAGE_DRIVER=local
STORAGE_ROOT=.local/storage

# --- Email (optional; MVP uses stream/console transport) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=tenders@su10.ru

# --- Public base URL used in invitation links ---
PUBLIC_WEB_URL=http://localhost:5173

# --- Optional ИНН lookup (DaData). Leave empty to use stub. ---
INN_LOOKUP_TOKEN=
