# Server env template for zakupki. On the VPS this becomes /opt/portals/zakupki/.env.production
# (chmod 600, NEVER committed). docker-compose reads it via env_file.
# Fill DATABASE_URL + JWT secrets with real values (secret-safe, see deploy/SECURITY.md).

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3000
TRUST_PROXY=true

# Public URLs (behind infra-nginx TLS on zak.su10.ru)
WEB_ORIGIN=https://zak.su10.ru
PUBLIC_WEB_URL=https://zak.su10.ru

# --- Yandex Managed PostgreSQL (verify-full). Port is usually 6432. ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:6432/DBNAME
# CA path INSIDE the container (mounted from ../certs/yandex-root.crt).
DATABASE_SSL_CA=/app/certs/yandex-root.crt

# --- Auth secrets — use long random strings (openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# --- File storage (mounted volume zakupki-storage) ---
STORAGE_DRIVER=local
STORAGE_ROOT=/var/lib/zakupki/storage

# --- Email (optional; MVP uses console transport when empty) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=tenders@su10.ru

# --- Optional ИНН lookup (DaData) ---
INN_LOOKUP_TOKEN=
