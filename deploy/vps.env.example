# Copy this to a ROOT-ONLY location OUTSIDE the repo and fill it in:
#   /root/.config/zakupki/vps.env   (chmod 600)
#
# NEVER commit the filled-in version. NEVER cat/echo it in a shared session.
# deploy/vps.sh reads it and uses SSH_ASKPASS so the passphrase never leaks.
# See deploy/SECURITY.md.

VPS_HOST=89.232.188.170
VPS_PORT=22
VPS_USER=corpsu
VPS_SSH_KEY=/root/.ssh/ed25519_kg_217

# Passphrase of VPS_SSH_KEY. Two options:
#  (A) Fill it in for hands-off deploys (stored plaintext in this 600 file).
#  (B) Leave it EMPTY to be prompted once per boot (loads the ssh-agent).
VPS_KEY_PASSPHRASE=
