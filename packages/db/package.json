{
  "name": "@zakupki/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "tsx src/reset.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint'",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@zakupki/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
